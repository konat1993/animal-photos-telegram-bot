# Skopiuj do .env obok docker-compose.yml na serwerze:
#   cp .env.docker.example .env
# Uzupełnij wartości. Nazwy muszą być zgodne z backend/app/core/config.py i frontend/lib/supabase.ts

# --- Frontend (build-time — po zmianie zrób: docker compose build --no-cache frontend)
NEXT_PUBLIC_SUPABASE_URL=https://qwerty.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# --- Backend (runtime)
TELEGRAM_BOT_TOKEN=...
SUPABASE_URL=https://qwerty.supabase.co
SUPABASE_SECRET_KEY=eyJ...
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Opcjonalnie zamiast SUPABASE_SECRET_KEY (legacy):
# SUPABASE_SERVICE_ROLE_KEY=
