# Copy to .env next to docker-compose.yml on the server:
#   cp .env.docker.example .env
# Fill in the values. Names must match those in backend/app/core/config.py and frontend/lib/supabase.ts

# --- Frontend (build-time — after any change, run: docker compose build --no-cache frontend)
NEXT_PUBLIC_SUPABASE_URL=https://qwerty.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# --- Backend (runtime)
TELEGRAM_BOT_TOKEN=...
SUPABASE_URL=https://qwerty.supabase.co
SUPABASE_SECRET_KEY=eyJ...
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
PUBLIC_DASHBOARD_URL=https://animal-photos-telegram-bot.cc

# Optionally instead of SUPABASE_SECRET_KEY (legacy):
# SUPABASE_SERVICE_ROLE_KEY=
